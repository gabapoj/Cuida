# Cuida — local environment variables
# Copy to .env.local and fill in values
# cp .env.local.example .env.local

# ─── App ──────────────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────────────────────────
# Individual parts (used to build connection strings)
DB_ENDPOINT=localhost
DB_PORT=5432
DB_NAME=cuida
DB_USER=postgres
DB_PASSWORD=postgres
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=postgres

# Or override the full URLs directly:
# ASYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cuida
# ADMIN_DB_URL=postgresql://postgres:postgres@localhost:5432/cuida

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ─── Phase 2: Auth ────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ─── Phase 2: Email (AWS SES) ─────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# SES_FROM_EMAIL=noreply@cuida.app
# SES_FROM_NAME=Cuida

# ─── Phase 3: LLM Providers ───────────────────────────────────────────────────
LLM_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Phase 3: Speech-to-Text ──────────────────────────────────────────────────
STT_PROVIDER=deepgram
# DEEPGRAM_API_KEY=

# ─── Phase 3: Text-to-Speech ──────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=

# ─── Phase 3: Telephony ───────────────────────────────────────────────────────
TELEPHONY_PROVIDER=telnyx
# TELNYX_API_KEY=
# TELNYX_PUBLIC_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ─── Phase 4: AWS / Infra ─────────────────────────────────────────────────────
# AWS_ACCOUNT_ID=
# S3_BUCKET=cuida-audio-dev
