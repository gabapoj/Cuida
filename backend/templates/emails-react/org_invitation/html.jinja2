<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
    <style></style>
  </head>
  <body style="background-color:rgb(250,247,242);margin:0">
    <!--$--><!--html--><!--head-->
    <div
      style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0"
      data-skip-in-text="true">
      You've been invited to join Nearwise
      <div>
         ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏
      </div>
    </div>
    <!--body-->
    <table
      border="0"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      align="center">
      <tbody>
        <tr>
          <td
            style='background-color:rgb(250,247,242);margin:0rem;padding:0rem;font-family:Georgia,"Times New Roman",serif'>
            <table
              role="presentation"
              width="100%"
              cellpadding="0"
              cellspacing="0"
              style="background-color:rgb(250,247,242)">
              <tbody>
                <tr>
                  <td
                    align="center"
                    style="padding-bottom:2.5rem;padding-top:2.5rem;padding-right:1.25rem;padding-left:1.25rem">
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="max-width:560px;width:100%">
                      <tbody>
                        <tr style="width:100%">
                          <td>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="padding-bottom:2.5rem">
                              <tbody>
                                <tr>
                                  <td>
                                    <p
                                      style='font-size:22px;line-height:24px;font-family:Georgia,"Times New Roman",serif;color:rgb(28,26,24);letter-spacing:0.025em;margin:0rem;margin-top:0rem;margin-bottom:0rem;margin-left:0rem;margin-right:0rem'>
                                      Nearwise
                                    </p>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="background-color:rgb(255,255,255);border-radius:1rem;border-style:solid;border-width:1px;border-color:rgb(232,226,217);padding-right:2.5rem;padding-left:2.5rem;padding-bottom:3rem;padding-top:3rem">
                              <tbody>
                                <tr>
                                  <td>
                                    <p
                                      style='font-size:26px;line-height:1.25;font-family:Georgia,"Times New Roman",serif;color:rgb(28,26,24);margin:0rem;margin-bottom:1.25rem;margin-top:0rem;margin-left:0rem;margin-right:0rem'>
                                      You've been invited
                                    </p>
                                    <p
                                      style="font-size:15px;line-height:1.625;font-family:Arial,Helvetica,sans-serif;color:rgb(92,86,80);margin:0rem;margin-bottom:1.75rem;margin-top:0rem;margin-left:0rem;margin-right:0rem">
                                      <strong style="color:rgb(28,26,24)">{{ inviter_name }}</strong> has invited you to join their organisation on Nearwise. Click the button below to accept the invitation. This link expires in
                                      <!-- -->{{ expiration_hours }}<!-- -->
                                      hours.
                                    </p>
                                    <table
                                      align="center"
                                      width="100%"
                                      border="0"
                                      cellpadding="0"
                                      cellspacing="0"
                                      role="presentation"
                                      style="margin-bottom:2rem">
                                      <tbody>
                                        <tr>
                                          <td>
                                            <a
                                              href="{{ invitation_url }}"
                                              style="line-height:1.25;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(196,113,74);color:rgb(255,255,255);text-decoration-line:none;border-radius:9999px;padding-right:32px;padding-left:32px;padding-bottom:14px;padding-top:14px;font-family:Arial,Helvetica,sans-serif;font-weight:500;font-size:15px;letter-spacing:0.025em;border-style:none"
                                              target="_blank"
                                              ><span
                                                ><!--[if mso
                                                  ]><i
                                                    style="mso-font-width:400%;mso-text-raise:21"
                                                    hidden
                                                    >&#8202;&#8202;&#8202;&#8202;</i
                                                  ><!
                                                [endif]--></span
                                              ><span
                                                style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:10.5px"
                                                >Accept invitation →</span
                                              ><span
                                                ><!--[if mso
                                                  ]><i
                                                    style="mso-font-width:400%"
                                                    hidden
                                                    >&#8202;&#8202;&#8202;&#8202;&#8203;</i
                                                  ><!
                                                [endif]--></span
                                              ></a
                                            >
                                          </td>
                                        </tr>
                                      </tbody>
                                    </table>
                                    <hr
                                      style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,226,217);margin-bottom:1.75rem;margin-top:1.75rem" />
                                    <p
                                      style="font-size:12px;line-height:24px;font-family:Arial,Helvetica,sans-serif;font-weight:500;color:rgb(154,147,138);text-transform:uppercase;letter-spacing:0.1em;margin:0rem;margin-bottom:0.5rem;margin-top:0rem;margin-left:0rem;margin-right:0rem">
                                      Or copy this link
                                    </p>
                                    <div
                                      style="background-color:rgb(253,249,244);border-style:solid;border-width:1px;border-color:rgb(232,226,217);border-radius:0.75rem;padding-right:1rem;padding-left:1rem;padding-bottom:0.875rem;padding-top:0.875rem">
                                      <p
                                        style='font-size:12px;line-height:1.5;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;word-break:break-all;margin:0rem;color:rgb(92,86,80);margin-top:0rem;margin-bottom:0rem;margin-left:0rem;margin-right:0rem'>
                                        {{ invitation_url }}
                                      </p>
                                    </div>
                                    <hr
                                      style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,226,217);margin-bottom:1.75rem;margin-top:1.75rem" />
                                    <div
                                      style="background-color:rgb(253,249,244);border-radius:0.75rem;border-style:solid;border-width:1px;border-color:rgb(232,226,217);padding-right:1rem;padding-left:1rem;padding-bottom:1rem;padding-top:1rem">
                                      <p
                                        style="font-size:0.875rem;line-height:1.625;font-family:Arial,Helvetica,sans-serif;color:rgb(92,86,80);margin:0rem;margin-top:0rem;margin-bottom:0rem;margin-left:0rem;margin-right:0rem">
                                        <strong
                                          style="color:rgb(28,26,24);font-weight:600"
                                          >Didn&#x27;t expect this?</strong
                                        ><br />You can safely ignore this email.
                                        This link can only be used once and
                                        expires automatically.
                                      </p>
                                    </div>
                                    <p
                                      style='font-size:1rem;line-height:1.5;font-family:Georgia,"Times New Roman",serif;color:rgb(28,26,24);margin-top:2rem;margin-bottom:0rem'>
                                      Warmly,<br /><span
                                        style="color:rgb(196,113,74)"
                                        >The Nearwise Team</span
                                      >
                                    </p>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="padding-top:2rem;text-align:center">
                              <tbody>
                                <tr>
                                  <td>
                                    <p
                                      style="font-size:0.75rem;line-height:1.3333333333333333;font-family:Arial,Helvetica,sans-serif;color:rgb(154,147,138);margin:0rem;margin-bottom:0.25rem;margin-top:0rem;margin-left:0rem;margin-right:0rem">
                                      © 2026 Nearwise
                                    </p>
                                    <p
                                      style="font-size:11px;line-height:24px;font-family:Arial,Helvetica,sans-serif;color:rgb(181,175,167);margin:0rem;margin-top:0rem;margin-bottom:0rem;margin-left:0rem;margin-right:0rem">
                                      This email was sent because someone invited you to their organisation.
                                    </p>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
    <!--/$-->
  </body>
</html>
