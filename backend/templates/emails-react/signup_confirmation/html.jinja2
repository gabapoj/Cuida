<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
    <style>
      .md_my-12{@media (width>=48rem){margin-bottom:3rem!important;margin-top:3rem!important}}.md_mb-6{@media (width>=48rem){margin-bottom:1.5rem!important}}.md_rounded-xl{@media (width>=48rem){border-radius:0.75rem!important}}.md_border{@media (width>=48rem){border-style:var(--tw-border-style)!important;border-width:1px!important}}.md_border-neutral-100{@media (width>=48rem){border-color:rgb(245,245,245)!important}}.md_bg-neutral-50{@media (width>=48rem){background-color:rgb(250,250,250)!important}}.md_p-12{@media (width>=48rem){padding:3rem!important}}.md_px-4{@media (width>=48rem){padding-right:1rem!important;padding-left:1rem!important}}.md_py-12{@media (width>=48rem){padding-bottom:3rem!important;padding-top:3rem!important}}.md_pb-8{@media (width>=48rem){padding-bottom:2rem!important}}.md_shadow-sm{@media (width>=48rem){--tw-shadow:0 1px 3px 0 var(--tw-shadow-color, rgb(0 0 0 / 0.1)),0 1px 2px -1px var(--tw-shadow-color, rgb(0 0 0 / 0.1))!important;box-shadow:var(--tw-inset-shadow),var(--tw-inset-ring-shadow),var(--tw-ring-offset-shadow),var(--tw-ring-shadow),var(--tw-shadow)!important}}
    </style>
  </head>
  <body
    class="md_bg-neutral-50 md_py-12 md_px-4"
    style="background-color:rgb(255,255,255);margin:0">
    <div
      style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0"
      data-skip-in-text="true">
      Welcome to Cuida — your account is ready
    </div>
    <table
      border="0"
      width="100%"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
      align="center">
      <tbody>
        <tr>
          <td
            style='background-color:rgb(255,255,255);font-family:ui-sans-serif,system-ui,sans-serif,"Apple Color Emoji","Segoe UI Emoji","Segoe UI Symbol","Noto Color Emoji";margin:0;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale'>
            <table
              align="center"
              width="100%"
              class="md_rounded-xl md_p-12 md_shadow-sm md_border md_border-neutral-100"
              border="0"
              cellpadding="0"
              cellspacing="0"
              role="presentation"
              style="max-width:560px;background-color:rgb(255,255,255);padding:1rem;margin-right:auto;margin-left:auto">
              <tbody>
                <tr style="width:100%">
                  <td>
                    <!-- Header -->
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      class="md_pb-8"
                      style="padding-bottom:1.5rem;margin-bottom:1.5rem;border-bottom-style:solid;border-bottom-width:1px;border-color:rgb(245,245,245)">
                      <tbody>
                        <tr>
                          <td>
                            <p style="font-size:1.25rem;line-height:1.4;font-weight:600;letter-spacing:-0.025em;margin:0">
                              Cuida
                            </p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                    <!-- Content -->
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="padding:0">
                      <tbody>
                        <tr>
                          <td>
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="margin-bottom:1.5rem">
                              <tbody>
                                <tr>
                                  <td>
                                    <h1 style="font-size:28px;font-weight:700;margin:0;line-height:1.25;letter-spacing:-0.025em">
                                      Welcome to Cuida
                                    </h1>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <p style="font-size:1rem;line-height:1.625;margin-bottom:1.5rem;font-weight:400;margin-top:16px;color:rgb(100,100,100)">
                              Your account for <strong style="font-weight:600;color:rgb(10,10,10)">{{ user_email }}</strong> is
                              all set. We're glad to have you here.
                            </p>
                            <p style="font-size:1rem;line-height:1.625;margin-bottom:2rem;font-weight:400;color:rgb(100,100,100)">
                              Cuida helps you stay connected with your loved ones. Get started by exploring the app.
                            </p>
                            <!-- CTA button -->
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="margin-bottom:2rem;margin-top:2rem;text-align:center">
                              <tbody>
                                <tr>
                                  <td>
                                    <a
                                      href="https://app.cuida.app"
                                      style="line-height:1.25;text-decoration:none;display:inline-flex;max-width:100%;align-items:center;justify-content:center;gap:0.5rem;padding:14px 28px;background-color:rgb(10,10,10);color:rgb(255,255,255);border-radius:9999px;font-weight:500;font-size:15px;text-align:center;border:none"
                                      target="_blank"
                                      >Open Cuida →</a
                                    >
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                            <!-- Help notice -->
                            <table
                              align="center"
                              width="100%"
                              border="0"
                              cellpadding="0"
                              cellspacing="0"
                              role="presentation"
                              style="margin-top:3rem;padding:1rem;background-color:rgb(250,250,250);border-radius:0.5rem;border:1px solid rgb(245,245,245)">
                              <tbody>
                                <tr>
                                  <td>
                                    <p style="font-size:0.875rem;line-height:1.625;margin:0;color:rgb(100,100,100)">
                                      <strong style="font-weight:600;color:rgb(10,10,10)">Need help?</strong><br />
                                      Reply to this email and we'll get back to you as soon as we can.
                                    </p>
                                  </td>
                                </tr>
                              </tbody>
                            </table>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                    <!-- Footer -->
                    <hr
                      class="md_my-12 md_mb-6"
                      style="width:100%;border:none;border-top:1px solid rgb(245,245,245);margin-bottom:1rem;margin-top:2rem" />
                    <table
                      align="center"
                      width="100%"
                      border="0"
                      cellpadding="0"
                      cellspacing="0"
                      role="presentation"
                      style="text-align:center">
                      <tbody>
                        <tr>
                          <td>
                            <p style="font-size:13px;line-height:1.5;margin-bottom:0.5rem;margin-top:0.5rem;font-weight:400;color:rgb(100,100,100)">
                              Sent securely with
                              <a
                                href="https://cuida.app"
                                style="color:rgb(10,10,10);text-decoration:none;font-weight:500"
                                target="_blank"
                                >Cuida</a
                              >
                            </p>
                            <p style="font-size:0.75rem;line-height:1.5;color:rgb(161,161,161);margin-top:0.25rem;margin-bottom:0">
                              © 2025 Cuida. All rights reserved.
                            </p>
                          </td>
                        </tr>
                      </tbody>
                    </table>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
